# KAIZORA staging environment

NEXT_PUBLIC_APP_URL=https://staging.kaizora.com
NEXT_PUBLIC_SITE_URL=https://staging.kaizora.com

NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-supabase-service-role-key

STRIPE_SECRET_KEY=sk_test_or_stage_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_or_stage_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_staging_webhook_secret

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=staging@example.com
SMTP_PASS=your-staging-smtp-password
BILLING_FROM_EMAIL=billing-staging@example.com

OPENAI_API_KEY=your-staging-openai-api-key
GEMINI_API_KEY=your-staging-gemini-api-key
REPLICATE_API_TOKEN=your-staging-replicate-token
FAL_AI_KEY=your-staging-fal-key
ELEVENLABS_API_KEY=your-staging-elevenlabs-key
ELEVENLABS_VOICE_ID=your-staging-voice-id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

KAIZORA_GOOGLE_AI_PROVIDER=vertex
GOOGLE_CLOUD_PROJECT=your-staging-google-cloud-project
GOOGLE_CLOUD_LOCATION=global
GOOGLE_CLOUD_CREDENTIALS_JSON='{"type":"service_account","project_id":"your-staging-project","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"service-account@your-staging-project.iam.gserviceaccount.com"}'

KAIZORA_SERVER_LOGS_ENABLED=false
KAIZORA_LOG_GEMINI=false
KAIZORA_LOG_GEMINI_USAGE=false
KAIZORA_LOG_VERTEX_USAGE=false
KAIZORA_LOG_API_DECISION_LAYER_AGENT_CHAT=false
KAIZORA_LOG_API_DECISION_LAYER_GREETING=false
KAIZORA_LOG_API_DECISION_LAYER_TTS=false
KAIZORA_LOG_API_ASSET_MODERATION=false
KAIZORA_LOG_API_MARKETPLACE_EVALUATE=false
KAIZORA_LOG_API_MARKETPLACE_ASSISTANT=false
NEXT_PUBLIC_DECISION_LAYER_INPUT_DEBUG=false
NEXT_PUBLIC_MARKETPLACE_UPLOAD_DEBUG=false

FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
FFPROBE_PATH=/opt/homebrew/bin/ffprobe
