# KAIZORA local/default environment

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_or_sk_live_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_or_pk_live_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=info@example.com
SMTP_PASS=your-smtp-password
BILLING_FROM_EMAIL=billing@example.com

# AI providers
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
REPLICATE_API_TOKEN=your-replicate-api-token
FAL_AI_KEY=your-fal-ai-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Google AI provider
KAIZORA_GOOGLE_AI_PROVIDER=vertex
GOOGLE_CLOUD_PROJECT=your-google-cloud-project
GOOGLE_CLOUD_LOCATION=global
GOOGLE_CLOUD_CREDENTIALS_JSON='{"type":"service_account","project_id":"your-project","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"service-account@your-project.iam.gserviceaccount.com"}'
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/vertex-api-file.json

# Logging
KAIZORA_SERVER_LOGS_ENABLED=false
KAIZORA_LOG_GEMINI=false
KAIZORA_LOG_GEMINI_USAGE=false
KAIZORA_LOG_VERTEX_USAGE=false
KAIZORA_LOG_API_DECISION_LAYER_AGENT_CHAT=false
KAIZORA_LOG_API_DECISION_LAYER_GREETING=false
KAIZORA_LOG_API_DECISION_LAYER_TTS=false
KAIZORA_LOG_API_ASSET_MODERATION=false
KAIZORA_LOG_API_MARKETPLACE_EVALUATE=false
KAIZORA_LOG_API_MARKETPLACE_ASSISTANT=false
NEXT_PUBLIC_DECISION_LAYER_INPUT_DEBUG=false
NEXT_PUBLIC_MARKETPLACE_UPLOAD_DEBUG=false

# Media tools
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
FFPROBE_PATH=/opt/homebrew/bin/ffprobe
